{
    "name": "verturin/chastitytracker",
    "type": "phpbb-extension",
    "description": "Extension de suivi de chasteté avec calendrier visuel et statistiques",
    "homepage": "https://github.com/verturin/chastitytracker",
    "version": "3.4.0",
	"time": "2026-04-20",	
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "verturin",
            "homepage": "https://github.com/verturin",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=7.1",
        "composer/installers": "~1.0"
    },
    "extra": {
        "display-name": "Chastity Tracker",
        "soft-require": {
            "phpbb/phpbb": ">=3.2.0"
		},
		"version-check": {
			"host": "verturin.github.io",
			"directory": "/chastitytracker",
			"filename": "chastitytracker_version.json",
			"ssl": true

        }
    }
}
